  ▸ fn compute_y_t8  [in: img_NHWC(1×8×8×4)]  [out: y(1×4×4×4)]  [temps: img_NHWC_NCHW(1×4×8×8)]
    for i0 in [0, 1):
      for i1 in [0, 4):
        for i2 in [0, 8):
          for i3 in [0, 8):
            img_NHWC_NCHW[i0, i1, i2, i3] = img_NHWC[i0, i2, i3, i1]
    for n in [0, 1):
      for c in [0, 4):
        for oi in [0, 4):
          for oj in [0, 4):
            y[n, c, oi, oj] = -Inf()
            for ki in [0, 2):
              for kj in [0, 2):
                y[n, c, oi, oj] = max(y[n, c, oi, oj], img_NHWC_NCHW[n, c, ((2.0 * oi) + ki), ((2.0 * oj) + kj)])
······························································
  ▸ fn compute_linear_out_t_fused_1_0  [in: x(32×128), fc1.weight(128×64), fc1.bias(64), fc2.weight(64×32), fc2.bias(32)]  [out: linear_out(32×32)]  [temps: linear_out(32×64)]
    for i in [0, 32):
      for j in [0, 64):
        linear_out[i, j] = fc1.bias[j]
        for k in [0, 128):
          linear_out[i, j] += (x[i, k] * fc1.weight[k, j])
    for i in [0, 32):
      for j in [0, 32):
        linear_out[i, j] = fc2.bias[j]
        for k in [0, 64):
          linear_out[i, j] += (linear_out[i, k] * fc2.weight[k, j])
